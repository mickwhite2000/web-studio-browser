<Window x:Class="Web_Studio_Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource AppBg}"
        MinWidth="1400"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowState="Maximized">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="42"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="8"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ============================================ -->
        <!-- [[THEMES]] START: Theme Brushes (DynamicResource) -->
        <!-- ============================================ -->

        <!-- Core surfaces -->
        <SolidColorBrush x:Key="AppBg" Color="#FFF6F1EA"/>
        <SolidColorBrush x:Key="TopBarBg" Color="#FFF6F1EA"/>

        <!-- Controls -->
        <SolidColorBrush x:Key="ButtonBg" Color="#FFEDE6DB"/>
        <SolidColorBrush x:Key="ButtonBorder" Color="#FFB9A07B"/>
        <SolidColorBrush x:Key="ButtonHoverBg" Color="#FFF3EEE6"/>
        <SolidColorBrush x:Key="ButtonPressedBg" Color="#FFE2D6C6"/>

        <!-- Lines / borders -->
        <SolidColorBrush x:Key="DividerBrush" Color="#FFE0D1BE"/>

        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimary" Color="#FF1F1A12"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF6E6254"/>

        <!-- Cards / panels -->
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CardBorder" Color="#FFE7DED2"/>

        <!-- Inputs -->
        <SolidColorBrush x:Key="InputBg" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="InputBorder" Color="#FFB9A07B"/>

        <!-- ============================================ -->
        <!-- [[THEMES]] END: Theme Brushes -->
        <!-- ============================================ -->

        <!-- Rounded top bar button style -->
        <Style x:Key="TopBarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  RecognizesAccessKey="True"
                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Toggle icon button (for shield) to match the rest -->
        <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
        Background="{DynamicResource TopBarBg}"
        BorderBrush="{DynamicResource DividerBrush}"
        BorderThickness="0,0,0,1"
        Padding="10,9"
        shell:WindowChrome.IsHitTestVisibleInChrome="True"
        MouseLeftButtonDown="TopBar_MouseLeftButtonDown">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- WIN CONTROLS (flush left, NO capsule border) -->
                <StackPanel Grid.Column="0"
            Orientation="Horizontal"
            VerticalAlignment="Center"
            Margin="0,0,10,0">

                    <Button x:Name="WinMinTopButton"
            Style="{StaticResource IconButtonStyle}"
            Content="—"
            ToolTip="Minimise"
            Margin="0,0,4,0"
            Click="WinMin_Click"/>
                    <Button x:Name="WinMaxTopButton"
            Style="{StaticResource IconButtonStyle}"
            Content="▢"
            ToolTip="Maximise / Restore"
            Click="WinMaxRestore_Click"/>

                    <Button x:Name="WinCloseTopButton"
            Style="{StaticResource IconButtonStyle}"
            Content="✕"
            ToolTip="Close"
            Click="WinClose_Click"/>

                    <Border Width="1"
        Height="22"
        Background="{DynamicResource DividerBrush}"
        Margin="10,0,10,0"
        VerticalAlignment="Center"/>

                </StackPanel>

                <!-- LEFT BUTTONS -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="SettingsButton"
        Style="{StaticResource IconButtonStyle}"
        Content="⚙"
        ToolTip="Settings"
        FontSize="15"
        Width="40"
        Click="SettingsButton_Click"/>

                    <!-- Settings (Quick URLs) -->
                    <Popup x:Name="SettingsDropdown"
                           PlacementTarget="{Binding ElementName=SettingsButton}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False">
                        <Border Background="{DynamicResource TopBarBg}"
        BorderBrush="{DynamicResource DividerBrush}"
        BorderThickness="2"
        CornerRadius="16"
        Padding="14"
        Margin="0,8,0,0"
        SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.22"/>
                            </Border.Effect>
                            <ScrollViewer MaxHeight="520"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>

                                    <TextBlock Text="Quick URLs"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Margin="6,2,6,10"/>

                                    <UniformGrid Columns="4" Rows="5" Margin="2,0,2,0">
                                        <Button x:Name="PresetBtn1"  Tag="0"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn2"  Tag="1"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn3"  Tag="2"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn4"  Tag="3"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>

                                        <Button x:Name="PresetBtn5"  Tag="4"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn6"  Tag="5"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn7"  Tag="6"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn8"  Tag="7"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>

                                        <Button x:Name="PresetBtn9"  Tag="8"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn10" Tag="9"  Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn11" Tag="10" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn12" Tag="11" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>

                                        <Button x:Name="PresetBtn13" Tag="12" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn14" Tag="13" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn15" Tag="14" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn16" Tag="15" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>

                                        <Button x:Name="PresetBtn17" Tag="16" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn18" Tag="17" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn19" Tag="18" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                        <Button x:Name="PresetBtn20" Tag="19" Style="{StaticResource TopBarButtonStyle}" Content="(empty)" Click="PresetButton_Click"/>
                                    </UniformGrid>

                                    <TextBlock Text="Right-click a button to set/clear its URL."
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="6,10,6,0"/>

                                    <!-- Divider -->
                                    <Border Height="1"
        Background="{DynamicResource DividerBrush}"
        Margin="6,14,6,10"/>

                                    <!-- DNS -->
                                    <Grid Margin="6,0,6,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
               Text="DNS"
               FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimary}"
               VerticalAlignment="Center"/>

                                        <Button Grid.Column="1"
            Style="{StaticResource TopBarButtonStyle}"
            MinWidth="72"
            Content="Notes"
            Margin="8,0,0,0"
            Click="DnsNotes_Click"/>
                                    </Grid>

                                    <!-- DNS Mode -->
                                    <StackPanel Margin="6,8,6,0">
                                        <TextBlock Text="DNS Mode"
               Foreground="{DynamicResource TextSecondary}"
               FontSize="12"
               Margin="0,0,0,6"/>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource TopBarButtonStyle}"
                Content="System (Windows)"
                Click="DnsMode_System_Click"/>

                                            <Button Style="{StaticResource TopBarButtonStyle}"
                Content="Secure DNS (App)"
                Margin="8,0,0,0"
                Click="DnsMode_App_Click"/>

                                            <Button Style="{StaticResource TopBarButtonStyle}"
                Content="Apply to Windows"
                Margin="8,0,0,0"
                Click="DnsMode_Windows_Click"/>
                                        </StackPanel>

                                        <TextBlock x:Name="DnsModeStatusText"
               Text="Mode: System (Windows)"
               Foreground="{DynamicResource TextSecondary}"
               FontSize="12"
               Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <!-- DNS Presets -->
                                    <UniformGrid Columns="3" Margin="2,10,2,0">
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Cloudflare" Click="Dns_Cloudflare_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Quad9" Click="Dns_Quad9_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="OpenDNS" Click="Dns_OpenDns_Click"/>

                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="CleanBrowsing" Click="Dns_CleanBrowsing_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="AdGuard" Click="Dns_AdGuard_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Google" Click="Dns_Google_Click"/>

                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="System Default" Click="Dns_SystemDefault_Click"/>
                                    </UniformGrid>

                                    <!-- Restore Windows DNS -->
                                    <Button x:Name="RestoreWindowsDnsButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="Restore Windows DNS"
        Margin="6,10,6,0"
        Click="DnsRestore_Windows_Click"/>

                                    <TextBlock Text="App DNS uses Secure DNS (DoH) inside Web Studio Browser. Windows DNS changes require Admin."
           Foreground="{DynamicResource TextSecondary}"
           FontSize="12"
           Margin="6,8,6,0"/>

                                    <!-- Divider -->
                                    <Border Height="1"
        Background="{DynamicResource DividerBrush}"
        Margin="6,14,6,10"/>

                                    <!-- Search Engine -->
                                    <Grid Margin="6,0,6,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
               Text="Search Engine"
               FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimary}"
               VerticalAlignment="Center"/>

                                        <Button Grid.Column="1"
            Style="{StaticResource TopBarButtonStyle}"
            MinWidth="72"
            Content="Notes"
            Margin="8,0,0,0"
            Click="SearchNotes_Click"/>
                                    </Grid>

                                    <UniformGrid Columns="3" Margin="2,8,2,0">
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Mojeek" Click="Search_Mojeek_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="DuckDuckGo" Click="Search_DuckDuckGo_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Brave" Click="Search_Brave_Click"/>

                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Startpage" Click="Search_Startpage_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Qwant" Click="Search_Qwant_Click"/>
                                        <Button Style="{StaticResource TopBarButtonStyle}" Content="Google" Click="Search_Google_Click"/>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <!-- Privacy -->
                    <Button x:Name="PrivacyButton"
        Style="{StaticResource IconButtonStyle}"
        Content="🛡"
        ToolTip="Privacy"
        FontSize="15"
        Width="40"
        Click="PrivacyButton_Click"/>

                    <Popup x:Name="PrivacyDropdown"
                           PlacementTarget="{Binding ElementName=PrivacyButton}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False">
                        <Border Background="{DynamicResource TopBarBg}"
        BorderBrush="{DynamicResource DividerBrush}"
        BorderThickness="2"
        CornerRadius="16"
        Padding="14"
        Margin="0,8,0,0"
        SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.22"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Privacy"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Margin="6,2,6,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="PrivacyOffBtn"
            Style="{StaticResource TopBarButtonStyle}"
            Content="Off"
            Width="78"
            Click="PrivacyOff_Click"/>

                                    <Button x:Name="PrivacyBalancedBtn"
            Style="{StaticResource TopBarButtonStyle}"
            Content="Balanced"
            Width="92"
            Margin="8,0,0,0"
            Click="PrivacyBalanced_Click"/>

                                    <Button x:Name="PrivacyTrackingBtn"
            Style="{StaticResource TopBarButtonStyle}"
            Content="Tracking Only"
            Width="108"
            Margin="8,0,0,0"
            Click="PrivacyTracking_Click"/>

                                    <Button x:Name="PrivacyStrictBtn"
            Style="{StaticResource TopBarButtonStyle}"
            Content="Strict"
            Width="78"
            Margin="8,0,0,0"
            Click="PrivacyStrict_Click"/>
                                </StackPanel>

                                <Button x:Name="UpdateBlocklistButton"
                                        Style="{StaticResource TopBarButtonStyle}"
                                        Content="Update Blocklist"
                                        Margin="0,12,0,0"
                                        Click="UpdateBlocklist_Click"/>

                                <Button x:Name="PrivacyDeleteHistoryButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="Delete History"
        Margin="0,8,0,0"
        Click="PrivacyDeleteHistory_Click"/>

                                <Button x:Name="PrivacyNotesButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="About Privacy"
        Margin="0,8,0,0"
        Click="PrivacyNotes_Click"/>

                                <Border Height="1"
        Background="{DynamicResource DividerBrush}"
        Margin="6,14,6,10"/>

                                <TextBlock Text="Privacy Network"
           FontWeight="SemiBold"
           Foreground="{DynamicResource TextPrimary}"
           Margin="6,2,6,10"/>

                                <Button x:Name="HideIpButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="Hide IP: Off"
        Margin="0,0,0,8"
        Click="HideIpButton_Click"/>

                                <Button x:Name="ChangeLocationButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="Change Location: Australia"
        Margin="0,0,0,0"
        Click="ChangeLocationButton_Click"/>

                                <TextBlock x:Name="PrivacyNetworkStatusText"
           Text="Privacy network not connected"
           Foreground="{DynamicResource TextSecondary}"
           FontSize="12"
           Margin="6,10,6,0"/>

                                <TextBlock x:Name="PrivacyStatusText"
                                           Text=""
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="6,10,6,0"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Button x:Name="ThemesButton"
        Style="{StaticResource IconButtonStyle}"
        Content="◑"
        ToolTip="Themes"
        FontSize="24"
        Width="40"
        Click="ThemesButton_Click"/>

                    <Border Width="1" Height="22" Background="{DynamicResource DividerBrush}" Margin="8,0,8,0"/>

                    <!-- HOME (Home = Quick URL 1) -->
                    <Button x:Name="HomeTopButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="🏠"
                            ToolTip="Home (Quick URL 1)"
                            FontSize="16"
                            Width="40"
                            Click="HomeTopButton_Click"/>
                    <Button x:Name="BackTopButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="◀"
                            ToolTip="Back"
                            Click="BackTopButton_Click"/>
                    <Button x:Name="ForwardTopButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="▶"
                            ToolTip="Forward"
                            Click="ForwardTopButton_Click"/>
                    <Button x:Name="ReloadTopButton"
        Style="{StaticResource IconButtonStyle}"
        Content="↻"
        ToolTip="Refresh"
        Margin="6,0,0,0"
        Click="ReloadButton_Click"/>

                    <Button x:Name="SnapBackTopButton"
        Style="{StaticResource IconButtonStyle}"
        Content="⧉"
        ToolTip="Snapback"
        FontSize="16"
        Width="40"
        Margin="6,0,0,0"
        Click="SnapBackTopButton_Click"/>

                </StackPanel>
                
                <!-- CENTER -->
                <Grid Grid.Column="2"
      VerticalAlignment="Center"
      Margin="12,0">
                    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                        <!-- Status dot -->
                        <Border x:Name="StatusIndicatorHost"
        Width="22"
        Height="22"
        Margin="0,0,10,0"
        Background="Transparent"
        CornerRadius="11"
        VerticalAlignment="Center"
        ToolTip="Status: Safe"
        Cursor="Hand"
        MouseLeftButtonUp="StatusIndicatorHost_MouseLeftButtonUp">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                          ShadowDepth="0"
                          Opacity="0.85"/>
                            </Border.Effect>

                            <Ellipse x:Name="StatusIndicator"
             Width="10"
             Height="10"
             Fill="#FF57D657"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="12"
                              ShadowDepth="0"
                              Color="#FF57D657"
                              Opacity="0.9"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>

                        <Popup x:Name="StatusPopup"
       PlacementTarget="{Binding ElementName=StatusIndicatorHost}"
       Placement="Bottom"
       StaysOpen="False"
       AllowsTransparency="True"
       PopupAnimation="Fade">

                            <Border Background="{DynamicResource TopBarBg}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="2"
            CornerRadius="16"
            Padding="14"
            Margin="0,8,0,0"
            SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.22"/>
                                </Border.Effect>

                                <StackPanel Width="260">

                                    <TextBlock Text="STATUS"
           FontWeight="SemiBold"
           FontSize="13"
           Foreground="{DynamicResource TextPrimary}"
           Margin="0,0,0,10"/>

                                    <TextBlock x:Name="StatusPopupSummaryText"
           Text="Safe"
           FontSize="14"
           FontWeight="SemiBold"
           Foreground="{DynamicResource TextPrimary}"
           Margin="0,0,0,8"/>

                                    <TextBlock x:Name="StatusPopupConnectionText"
                       Text="Connection: Secure"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,6"/>

                                    <TextBlock x:Name="StatusPopupTrackersText"
           Text="Trackers blocked: 0"
           Foreground="{DynamicResource TextPrimary}"
           Margin="0,0,0,6"/>

                                    <TextBlock x:Name="StatusPopupAdsText"
           Text="Ads blocked: 0"
           Foreground="{DynamicResource TextPrimary}"
           Margin="0,0,0,6"/>

                                    <TextBlock x:Name="StatusPopupPrivacyText"
                       Text="Privacy: Balanced"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,6"/>

                                    <TextBlock x:Name="StatusPopupCompatibilityText"
           Text=""
           Foreground="{DynamicResource TextPrimary}"
           Margin="0,0,0,6"/>

                                    <TextBlock x:Name="StatusPopupPageText"
                       Text="Page: Current page"
                       Foreground="{DynamicResource TextPrimary}"/>

                                    <TextBlock x:Name="StatusSummaryText"
           Text="Safe"
           FontSize="14"
           FontWeight="SemiBold"
           Foreground="{DynamicResource TextPrimary}"
           Margin="0,0,0,8"/>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <!-- Address + Go -->
                        <Grid MaxWidth="1250"
      VerticalAlignment="Center"
      HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="AddressBarBorder"
            Grid.Column="0"
            Height="42"
            CornerRadius="18"
            Background="{DynamicResource InputBg}"
            BorderBrush="{DynamicResource InputBorder}"
            BorderThickness="1.5"
            SnapsToDevicePixels="True"
            Padding="0">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
                                        <Setter Property="BorderThickness" Value="1.5" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=AddressBox, Path=IsKeyboardFocused}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBox x:Name="AddressBox"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="{DynamicResource TextPrimary}"
                 VerticalContentAlignment="Center"
                 Padding="14,0"
                 FontSize="14"
                 CaretBrush="{DynamicResource TextPrimary}"
                 KeyDown="AddressBox_KeyDown"
                 TextChanged="AddressBox_TextChanged"
                 LostKeyboardFocus="AddressBox_LostKeyboardFocus"
                 FocusVisualStyle="{x:Null}"
                 TextWrapping="NoWrap"
                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 PreviewMouseLeftButtonDown="AddressBox_PreviewMouseLeftButtonDown"
                 GotKeyboardFocus="AddressBox_GotKeyboardFocus"
                 Focusable="True"
                 IsReadOnly="False"/>
                            </Border>

                            <Button Grid.Column="1"
            Margin="8,0,0,0"
            Style="{StaticResource IconButtonStyle}"
            Content="➜"
            ToolTip="Navigate"
            Click="GoButton_Click"/>
                        </Grid>

                        <!-- PAGE MODE BUTTONS (1-4) -->
                        <StackPanel x:Name="PageModePanel"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="6,0,0,0">

                            <Button x:Name="Page1Button"
                    Style="{StaticResource TopBarButtonStyle}"
                    Content="1"
                    Width="34"
                    Height="34"
                    Padding="0"
                    FontWeight="SemiBold"
                    Click="Page1Button_Click"/>
                            <Button x:Name="Page2Button"
                    Style="{StaticResource TopBarButtonStyle}"
                    Content="2"
                    Width="34"
                    Height="34"
                    Padding="0"
                    FontWeight="SemiBold"
                    Click="Page2Button_Click"/>
                            <Button x:Name="Page3Button"
                    Style="{StaticResource TopBarButtonStyle}"
                    Content="3"
                    Width="34"
                    Height="34"
                    Padding="0"
                    FontWeight="SemiBold"
                    Click="Page3Button_Click"/>

                            <Button x:Name="Page4Button"
                    Style="{StaticResource TopBarButtonStyle}"
                    Content="4"
                    Width="34"
                    Height="34"
                    Padding="0"
                    FontWeight="SemiBold"
                    Margin="2,0,0,0"
                    Click="Page4Button_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <!-- RIGHT -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <Button x:Name="StudioButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="📑"
        Width="42"
        FontSize="16"
        ToolTip="Studio"
        Click="StudioButton_Click"/>

                    <Button x:Name="WebActionsButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="⚡"
        Width="42"
        FontSize="20"
        ToolTip="Web Actions"
        Click="WebActionsButton_Click"/>

                    <Popup x:Name="WebActionsDropdown"
       PlacementTarget="{Binding ElementName=WebActionsButton}"
       Placement="Bottom"
       AllowsTransparency="True"
       StaysOpen="False">
                        <Border Background="{DynamicResource TopBarBg}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="2"
            CornerRadius="14"
            Padding="10"
            Margin="0,6,0,0">
                            <StackPanel MinWidth="220">

                                <TextBlock Text="Web Actions"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="6,2,6,10"/>

                                <Button Style="{StaticResource TopBarButtonStyle}" Content="Print" Click="WebAction_Print_Click"/>
                                <Button x:Name="ShareButton"
        Style="{StaticResource TopBarButtonStyle}"
        Content="Share…"
        Click="WebAction_Share_Click">
                                    <Button.ContextMenu>
                                        <ContextMenu x:Name="ShareMenu">
                                            <MenuItem Header="Copy Link"
                      Click="ShareCopyLink_Click"/>
                                            <MenuItem Header="Copy Title + Link"
                      Click="ShareCopyTitleLink_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Email Link"
                      Click="ShareEmail_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <Button Style="{StaticResource TopBarButtonStyle}" Content="Bookmark / Favourite" Click="WebAction_Bookmark_Click"/>
                                <Button Style="{StaticResource TopBarButtonStyle}"
        Content="Bookmarks"
        Click="WebAction_ViewBookmarks_Click"/>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="6,8"/>

                                <Button Style="{StaticResource TopBarButtonStyle}" Content="Zoom In" Click="WebAction_ZoomIn_Click"/>
                                <Button Style="{StaticResource TopBarButtonStyle}" Content="Zoom Out" Click="WebAction_ZoomOut_Click"/>
                                <Button Style="{StaticResource TopBarButtonStyle}" Content="Zoom Reset" Click="WebAction_ZoomReset_Click"/>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="6,8"/>

                                <Button Style="{StaticResource TopBarButtonStyle}" Content="History" Click="WebAction_History_Click"/>
                                <Button Style="{StaticResource TopBarButtonStyle}" Content="Downloads" Click="WebAction_Downloads_Click"/>

                            </StackPanel>
                        </Border>
                    </Popup>

                    <Button x:Name="PowerOffButton"
                            Style="{StaticResource TopBarButtonStyle}"
                            Content="⏻"
                            Width="42"
                            FontSize="20"
                            ToolTip="Power"
                            Click="PowerOffButton_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <!-- Pages Host (1–4 panes) -->
            <Grid x:Name="PagesHost">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Page 1 Host -->
                <Border x:Name="PageHost1"
                        Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                        BorderThickness="2"
                        CornerRadius="0"
                        MouseDown="PageHost_MouseDown"
                        Tag="0">
                    <Grid>
                        <wv2:WebView2 x:Name="Web"
                                     PreviewMouseDown="WebView_PreviewMouseDown"
                                     GotKeyboardFocus="WebView_GotKeyboardFocus" />
                        <Border x:Name="LockOverlay1"
                                Background="#66FFFFFF"
                                Visibility="Collapsed"
                                IsHitTestVisible="True"/>
                    </Grid>
                </Border>

                <!-- Page 2 Host -->
                <Border x:Name="PageHost2"
                        Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="1"
                        BorderThickness="2"
                        CornerRadius="0"
                        Visibility="Collapsed"
                        MouseDown="PageHost_MouseDown"
                        Tag="1">
                    <Grid>
                        <wv2:WebView2 x:Name="Web2"
                                     PreviewMouseDown="WebView_PreviewMouseDown"
                                     GotKeyboardFocus="WebView_GotKeyboardFocus" />
                        <Border x:Name="LockOverlay2"
                                Background="#66FFFFFF"
                                Visibility="Collapsed"
                                IsHitTestVisible="True"/>
                    </Grid>
                </Border>

                <!-- Page 3 Host -->
                <Border x:Name="PageHost3"
                        Grid.Row="1" Grid.Column="1"
                        BorderThickness="2"
                        CornerRadius="0"
                        Visibility="Collapsed"
                        MouseDown="PageHost_MouseDown"
                        Tag="2">
                    <Grid>
                        <wv2:WebView2 x:Name="Web3"
                                     PreviewMouseDown="WebView_PreviewMouseDown"
                                     GotKeyboardFocus="WebView_GotKeyboardFocus" />
                        <Border x:Name="LockOverlay3"
                                Background="#66FFFFFF"
                                Visibility="Collapsed"
                                IsHitTestVisible="True"/>
                    </Grid>
                </Border>

                <!-- Page 4 Host -->
                <Border x:Name="PageHost4"
                        Grid.Row="1" Grid.Column="0"
                        BorderThickness="2"
                        CornerRadius="0"
                        Visibility="Collapsed"
                        MouseDown="PageHost_MouseDown"
                        Tag="3">
                    <Grid>
                        <wv2:WebView2 x:Name="Web4"
                                     PreviewMouseDown="WebView_PreviewMouseDown"
                                     GotKeyboardFocus="WebView_GotKeyboardFocus" />
                        <Border x:Name="LockOverlay4"
                                Background="#66FFFFFF"
                                Visibility="Collapsed"
                                IsHitTestVisible="True"/>
                    </Grid>
                </Border>

            </Grid>

        </Grid>

    </Grid>
</Window>